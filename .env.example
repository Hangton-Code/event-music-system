# Copy this file to ".env" and fill in your values.

# ---- Moderation (OFF by default) ----
# Songs are accepted from all guests with no filtering unless you turn this on.
# To enable Gemini moderation: set ENABLE_MODERATION=true AND provide a key below.
ENABLE_MODERATION=false

# Google AI Studio API key for Gemini moderation (only used when ENABLE_MODERATION=true).
# Get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gemini model used for moderation. List available models with: bun run check-gemini
GEMINI_MODEL=gemini-2.5-flash

# Set to "strict" for family-friendly-only filtering. Anything else = filter
# explicit/non-music only (the default).
MODERATION_MODE=default

# Port the server listens on.
PORT=45416

# REQUIRED for Docker (published-port setup): your server's LAN IP. The QR code
# guests scan uses this, so it must be an address their phones can reach.
# Find it on the server with:  hostname -I    (take the 192.168.x.x / 10.x.x.x one)
# Example: HOST_IP=192.168.1.50
# (Only leave blank if you run the app directly with `bun start`, not in Docker.)
HOST_IP=
