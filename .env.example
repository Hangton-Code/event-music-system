# Copy this file to ".env" and fill in your values.

# ---- Content filter (LLM moderation) ----
# The filter is controlled live from the host (projector) page, and host-page
# settings persist in data/settings.json — the values here only seed the very
# first boot. When ON but no LLM key is set, it accepts everything.
ENABLE_MODERATION=false

# LLM provider — any OpenAI-compatible chat API. Default is OpenRouter with
# DeepSeek V4 Flash (fast + ~free at this workload). Swap providers by changing
# these three values; no code changes needed.
#   OpenRouter: https://openrouter.ai/api/v1  (key: https://openrouter.ai/keys)
#               models: deepseek/deepseek-v4-flash, z-ai/glm-5.2, minimax/minimax-m3, ...
#   Kimi:       https://api.moonshot.ai/v1    (key: https://platform.moonshot.ai)
#   DeepSeek:   https://api.deepseek.com/v1
#   GLM:        https://open.bigmodel.cn/api/paas/v4
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-v4-flash

# Verify your key and list models with:  bun run check-llm

# Let the filter web-search each song (OpenRouter ONLY — uses OpenRouter's web
# plugin). The model then sees live results — usually the song's actual lyrics —
# so a clean title can't hide explicit content. Adds ~$0.005 per moderated
# request (Exa search) and a few seconds of latency. Leave false on other
# providers; they reject the extra field.
LLM_WEB_SEARCH=false

# "strict" = family-friendly only. Anything else = filter explicit/non-music only.
# Changeable live from the host page (the 過濾 pill cycles off/on/strict).
MODERATION_MODE=default

# What event this is — given to the moderation LLM so it can judge fit for the
# occasion (e.g. reject national anthems / political songs at a school event).
# Editable live from the host page (場景 button); this is just the initial value.
# Default: "a secondary school graduation dinner (prom-like party) in Hong Kong"
EVENT_CONTEXT=

# Password for the host (projector) page and its controls. Strongly recommended
# when the app is on a public domain — without it, anyone who finds the URL can
# skip/remove songs. Guests never need this. Empty = no login (trusted LAN).
HOST_PASSWORD=

# Port the app listens on (inside the container; the reverse proxy targets this).
PORT=45416

# ---- Public address (what the QR code points to) ----
# Behind a reverse proxy with a domain, set the full public URL. Guests scan a
# QR pointing here, and it must be reachable from their phones/data.
PUBLIC_URL=https://grad-din-music.hangton.net

# Fallback ONLY when PUBLIC_URL is blank (direct LAN access, no proxy): the
# server's LAN IP for the QR code. Find it with:  hostname -I
HOST_IP=
